generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ───────────────────────────────────────────

enum ProductType {
  book
  gift
  ladies
  gents
  other
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum CouponType {
  percent
  flat
}

enum ReturnStatus {
  requested
  approved
  rejected
  completed
}

// ── Users ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  isAdmin   Boolean  @default(false)
  banned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses     Address[]
  orders        Order[]
  cartItems     CartItem[]
  wishlistItems Wishlist[]
  reviews       Review[]

  @@map("users")
}

// ── Addresses ───────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String  @default("Home") // Home / Work / Other
  name       String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ── Products ────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  type        ProductType
  price       Int         // in paise (₹ × 100)
  originalPrice Int?
  inStock     Boolean     @default(true)
  badge       String?     // "NEW" | "BESTSELLER" | "FEATURED" | "ON SALE"
  rating      Float       @default(0)
  reviewCount Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Book-specific metadata (null for non-books)
  author          String?
  isbn            String?
  publisher       String?
  language        String?
  genre           String?
  pageCount       Int?
  edition         String?
  description     String?
  tableOfContents String?

  images    ProductImage[]
  variants  ProductVariant[]
  cartItems CartItem[]
  orderItems OrderItem[]
  wishlistItems Wishlist[]
  reviews   Review[]
  featured      HomepageFeatured[]
  popularBooks  HomepagePopularBook[]
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([categoryId])
  @@index([createdAt])
  @@index([inStock])
  @@map("products")
}

// ── Product Images ───────────────────────────────────

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  url          String
  cloudinaryId String  // public_id in Cloudinary e.g. shiabazaar/products/[slug]/filename
  alt          String?
  position     Int     @default(0) // sort order
  isCover      Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ── Product Variants (non-book) ──────────────────────

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  label     String  // e.g. "Small", "Black", "M"
  stock     Int     @default(0)
  price     Int?    // override product price if different

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("product_variants")
}

// ── Orders ───────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String?     // null = guest
  addressId       String?
  status          OrderStatus @default(pending)
  subtotal        Int         // paise
  discountAmount  Int         @default(0)
  shippingAmount  Int         @default(0)
  total           Int
  couponCode      String?
  razorpayOrderId String?     @unique
  razorpayPaymentId String?
  trackingNumber  String?
  trackingUrl     String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user           User?          @relation(fields: [userId], references: [id])
  address        Address?       @relation(fields: [addressId], references: [id])
  items          OrderItem[]
  returnRequests ReturnRequest[]

  @@index([userId])
  @@map("orders")
}

// ── Order Items ──────────────────────────────────────

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  title     String  // snapshot at time of order
  price     Int     // snapshot in paise
  qty       Int

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ── Cart ─────────────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  variantId String?
  qty       Int      @default(1)
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([userId, productId, variantId])
  @@map("cart_items")
}

// ── Wishlist ─────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}

// ── Reviews ──────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  orderId   String?  // verified buyer gate — must have a completed order
  rating    Int      // 1–5
  title     String?
  body      String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId]) // one review per user per product
  @@index([productId])
  @@map("reviews")
}

// ── Coupons ──────────────────────────────────────────

model Coupon {
  id         String     @id @default(cuid())
  code       String     @unique
  type       CouponType
  value      Int        // percent (0–100) or flat paise amount
  minOrder   Int        @default(0) // minimum order total in paise
  usageLimit Int?       // null = unlimited
  usageCount Int        @default(0)
  expiresAt  DateTime?
  active     Boolean    @default(true)
  createdAt  DateTime   @default(now())

  @@map("coupons")
}

// ── Return Requests ──────────────────────────────────

model ReturnRequest {
  id        String       @id @default(cuid())
  orderId   String
  reason    String
  status    ReturnStatus @default(requested)
  adminNote String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("return_requests")
}

// ── Shipping Zones ───────────────────────────────────

model ShippingZone {
  id    String @id @default(cuid())
  zone  String @unique // "A" | "B" | "C" | "D"
  label String         // display name
  price Int            // flat shipping fee in paise; 0 = free

  @@map("shipping_zones")
}

// ── Categories ───────────────────────────────────────

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  group    String    // "book" | "gift" | "other"
  active   Boolean   @default(true)
  position Int       @default(0)

  products Product[]

  @@map("categories")
}

// ── Homepage Content ─────────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  ctaLabel  String   @default("Shop Now")
  ctaUrl    String   @default("/products")
  imageUrl  String?
  cloudinaryId String?
  active    Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("banners")
}

model HomepageFeatured {
  id        String  @id @default(cuid())
  productId String
  pinned    Boolean @default(true)
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId])
  @@map("homepage_featured")
}

model HomepagePopularBook {
  id        String  @id @default(cuid())
  productId String
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId])
  @@map("homepage_popular_books")
}

model Popup {
  id        String   @id @default(cuid())
  title     String
  code      String?  // optional coupon code to display
  trigger   String   @default("page_load") // "page_load" | "exit_intent"
  delayMs   Int      @default(3000)
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("popups")
}
